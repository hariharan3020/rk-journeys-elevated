    "faqs": [
        {
            "q": "How do I book a cab?",
            "a": "Tap any Book Now button — we'll open WhatsApp with a ready-to-send message. You can also call us directly."
        },
        {
            "q": "Do you charge extra for tolls & permits?",
            "a": "Yes. Other state permits, border taxes, toll gate charges, and parking fees are billed on actuals in addition to the kilometre rate."
        },
        {
            "q": "Are your drivers experienced?",
            "a": "All our drivers are licensed, background-verified and have years of experience on outstation routes."
        },
        {
            "q": "Do you provide 24×7 service?",
            "a": "Yes. Our fleet operates round the clock across India, including holidays."
        },
        {
            "q": "Which cities do you serve?",
            "a": "We are based in Coimbatore and operate pan-India with a strong network across South India."
        },
        {
            "q": "Can I request a specific vehicle?",
            "a": "Absolutely. Etios, Swift Dzire and Ciaz are available on request based on availability."
        }
